{
  "manifest_version": 3,
  "name": "MeetShare Pro",
  "version": "1.2",
  "description": "Native MPV integration for high-performance Google Meet sharing.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "http://localhost/",
    "http://127.0.0.1/"
  ],
  "icons": {
    "128": "icon.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "meetshare-pro@sarath.local"
    }
  }
}
